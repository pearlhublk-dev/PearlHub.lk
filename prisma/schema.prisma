generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// User & Authentication
// ============================================================================

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified DateTime?
  password      String?
  name          String?
  phone         String?
  image         String?
  role          UserRole   @default(USER)
  verified      Boolean    @default(false)
  status        UserStatus @default(ACTIVE)
  
  // Timestamps
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  lastLoginAt   DateTime?
  
  // Relations
  accounts      Account[]
  sessions      Session[]
  provider      Provider?
  bookings      Booking[]  @relation("GuestBookings")
  reviews       Review[]
  notifications Notification[]
  messages      Message[]
  compliance    ComplianceRecord[]
  
  @@index([email])
  @@index([role])
  @@index([status])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  
  @@unique([identifier, token])
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  PROVIDER_STAY
  PROVIDER_VEHICLE
  PROVIDER_EVENT
  PROVIDER_SME
  COMPLIANCE_OFFICER
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

// ============================================================================
// Provider Management
// ============================================================================

model Provider {
  id                  String              @id @default(cuid())
  userId              String              @unique
  businessName        String
  businessRegistration String
  taxId               String?
  description         String?             @db.Text
  website             String?
  
  // Business Details
  categories          ProviderCategory[]
  commissionRate        Decimal             @default(10.00)
  paymentPartner      PaymentPartner      @default(BANK_TRANSFER)
  
  // Verification
  verificationStatus  VerificationStatus  @default(PENDING)
  verifiedAt          DateTime?
  verifiedBy          String?
  
  // Ratings
  rating              Decimal             @default(0.00)
  totalReviews        Int                 @default(0)
  totalBookings       Int                 @default(0)
  
  // Relations
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings            Listing[]
  complianceRecords   ComplianceRecord[]
  
  // Timestamps
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  
  @@index([userId])
  @@index([verificationStatus])
  @@index([rating])
}

model ComplianceRecord {
  id           String         @id @default(cuid())
  providerId   String
  type         ComplianceType
  documentUrl  String
  status       VerificationStatus @default(PENDING)
  submittedAt  DateTime       @default(now())
  reviewedAt   DateTime?
  reviewedBy   String?
  notes        String?
  
  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [reviewedBy], references: [id])
  
  @@index([providerId])
  @@index([type])
  @@index([status])
}

enum ProviderCategory {
  STAY
  HOTEL
  RESORT
  GUEST_HOUSE
  VACATION_RENTAL
  HOSTEL
  VEHICLE
  CAR
  VAN
  BUS
  MOTORCYCLE
  TUKTUK
  EVENT
  CONCERT
  SPORTS
  THEATER
  CONFERENCE
  WORKSHOP
  EXHIBITION
  SERVICE
  TOUR_GUIDE
  PHOTOGRAPHY
  CATERING
  TRANSPORT
}

enum PaymentPartner {
  STRIPE
  PAYPAL
  PAYHERE
  BANK_TRANSFER
  CASH
}

enum ComplianceType {
  BUSINESS_LICENSE
  INSURANCE
  SAFETY_CERTIFICATE
  TAX_CLEARANCE
  IDENTITY_VERIFICATION
  ADDRESS_VERIFICATION
  VEHICLE_REGISTRATION
  EVENT_PERMIT
}

enum VerificationStatus {
  PENDING
  IN_REVIEW
  VERIFIED
  REJECTED
  EXPIRED
}

// ============================================================================
// Listings (Stays, Vehicles, Events, Services)
// ============================================================================

model Listing {
  id            String        @id @default(cuid())
  providerId    String
  type          ListingType
  title         String
  description   String        @db.Text
  shortDescription String?    @db.VarChar(500)
  
  // Location
  address       String
  city          String
  district      String
  province      String
  postalCode    String?
  latitude      Decimal?
  longitude     Decimal?
  
  // Pricing
  basePrice     Decimal       @db.Decimal(10, 2)
  currency      String        @default("LKR")
  pricingUnit   PricingUnit   @default(PER_NIGHT)
  cleaningFee   Decimal?      @db.Decimal(10, 2)
  serviceFee    Decimal?      @db.Decimal(10, 2)
  
  // Details
  amenities     String[]
  images        String[]
  capacity      Json?
  rules         Json?
  
  // Status
  status        ListingStatus @default(DRAFT)
  featured      Boolean       @default(false)
  instantBook   Boolean       @default(false)
  
  // Ratings
  rating        Decimal       @default(0.00)
  reviewCount   Int           @default(0)
  
  // Relations
  provider      Provider      @relation(fields: [providerId], references: [id], onDelete: Cascade)
  bookings      Booking[]
  reviews       Review[]
  availability  Availability[]
  
  // SEO & Metadata
  slug          String?       @unique
  metaTitle     String?
  metaDescription String?
  
  // Timestamps
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  publishedAt   DateTime?
  
  @@index([providerId])
  @@index([type])
  @@index([status])
  @@index([city])
  @@index([rating])
  @@index([featured])
  @@index([slug])
}

model Availability {
  id          String    @id @default(cuid())
  listingId   String
  date        DateTime
  available   Boolean   @default(true)
  price       Decimal?  @db.Decimal(10, 2)
  minimumStay Int?      @default(1)
  
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  
  @@unique([listingId, date])
  @@index([listingId])
  @@index([date])
  @@index([available])
}

enum ListingType {
  STAY
  VEHICLE
  EVENT
  SERVICE
}

enum PricingUnit {
  PER_NIGHT
  PER_DAY
  PER_HOUR
  PER_PERSON
  PER_KM
  FIXED
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
  ARCHIVED
}

// ============================================================================
// Bookings & Reservations
// ============================================================================

model Booking {
  id              String        @id @default(cuid())
  listingId       String
  guestId         String
  providerId      String
  
  // Dates
  checkIn         DateTime
  checkOut        DateTime
  duration        Int           // in days/hours
  
  // Guests
  adults          Int           @default(1)
  children        Int           @default(0)
  infants         Int           @default(0)
  pets            Int           @default(0)
  
  // Pricing
  basePrice       Decimal       @db.Decimal(10, 2)
  cleaningFee     Decimal?      @db.Decimal(10, 2)
  serviceFee      Decimal       @db.Decimal(10, 2)
  taxAmount       Decimal       @db.Decimal(10, 2)
  discount        Decimal?      @db.Decimal(10, 2)
  totalAmount     Decimal       @db.Decimal(10, 2)
  currency        String        @default("LKR")
  
  // Status
  status          BookingStatus @default(PENDING)
  
  // Payment
  paymentStatus   PaymentStatus @default(PENDING)
  paymentMethod   PaymentMethod?
  paymentIntentId String?
  paidAt          DateTime?
  
  // Cancellation
  cancelledAt     DateTime?
  cancellationReason String?
  refundAmount    Decimal?      @db.Decimal(10, 2)
  
  // Additional
  specialRequests String?       @db.Text
  guestNotes      String?       @db.Text
  
  // Relations
  listing         Listing       @relation(fields: [listingId], references: [id])
  guest           User          @relation("GuestBookings", fields: [guestId], references: [id])
  review          Review?
  
  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  confirmedAt     DateTime?
  checkedInAt     DateTime?
  checkedOutAt    DateTime?
  completedAt     DateTime?
  
  @@index([listingId])
  @@index([guestId])
  @@index([status])
  @@index([checkIn])
  @@index([paymentStatus])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  COMPLETED
  CANCELLED_BY_GUEST
  CANCELLED_BY_PROVIDER
  NO_SHOW
  REFUNDED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  DISPUTED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  CASH
  EWALLET
  PAYPAL
}

// ============================================================================
// Reviews & Ratings
// ============================================================================

model Review {
  id          String       @id @default(cuid())
  bookingId   String       @unique
  listingId   String
  reviewerId  String
  
  // Ratings
  rating      Int          // 1-5 overall
  cleanliness Int?
  accuracy    Int?
  communication Int?
  location    Int?
  checkIn     Int?
  value       Int?
  
  // Content
  title       String?
  comment     String       @db.Text
  images      String[]
  
  // Engagement
  helpful     Int          @default(0)
  
  // Response
  response    String?      @db.Text
  respondedAt DateTime?
  
  // Status
  status      ReviewStatus @default(PENDING)
  
  // Relations
  booking     Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  listing     Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reviewer    User         @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  @@index([listingId])
  @@index([reviewerId])
  @@index([status])
  @@index([rating])
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

// ============================================================================
// Notifications & Messaging
// ============================================================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  data      Json?
  
  // Status
  read      Boolean          @default(false)
  readAt    DateTime?
  priority  NotificationPriority @default(NORMAL)
  
  // Relations
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt DateTime         @default(now())
  
  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

model Message {
  id         String @id @default(cuid())
  senderId   String
  receiverId String
  bookingId  String?
  
  content    String @db.Text
  attachments String[]
  
  // Status
  read       Boolean @default(false)
  readAt     DateTime?
  
  // Relations
  sender     User    @relation(fields: [senderId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt  DateTime @default(now())
  
  @@index([senderId])
  @@index([receiverId])
  @@index([bookingId])
  @@index([read])
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  PAYMENT_REFUNDED
  REVIEW_RECEIVED
  REVIEW_RESPONSE
  MESSAGE_RECEIVED
  LISTING_APPROVED
  LISTING_REJECTED
  VERIFICATION_COMPLETE
  VERIFICATION_REJECTED
  SYSTEM_ANNOUNCEMENT
  PROMOTION
  SECURITY_ALERT
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ============================================================================
// Analytics & Reporting
// ============================================================================

model AnalyticsEvent {
  id          String   @id @default(cuid())
  type        String
  userId      String?
  sessionId   String?
  
  // Event Data
  event       String
  properties  Json?
  
  // Context
  url         String?
  referrer    String?
  userAgent   String?
  ipAddress   String?
  
  // Timestamps
  createdAt   DateTime @default(now())
  
  @@index([type])
  @@index([userId])
  @@index([createdAt])
  @@index([event])
}

model DailyStats {
  id              String   @id @default(cuid())
  date            DateTime @unique
  
  // User Stats
  newUsers        Int      @default(0)
  activeUsers     Int      @default(0)
  
  // Booking Stats
  newBookings     Int      @default(0)
  completedBookings Int    @default(0)
  cancelledBookings Int    @default(0)
  totalRevenue    Decimal  @default(0) @db.Decimal(12, 2)
  
  // Listing Stats
  newListings     Int      @default(0)
  activeListings  Int      @default(0)
  
  // Review Stats
  newReviews      Int      @default(0)
  averageRating   Decimal? @db.Decimal(3, 2)
  
  @@index([date])
}

// ============================================================================
// Settings & Configuration
// ============================================================================

model SiteConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  
  // Metadata
  description String?
  updatedBy   String?
  
  // Timestamps
  updatedAt   DateTime @updatedAt
  
  @@index([key])
}

// ============================================================================
// Feature Flags
// ============================================================================

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  enabled     Boolean  @default(false)
  description String?
  
  // Targeting
  userPercentage Int   @default(100) // 0-100
  allowedRoles String[]
  
  // Timestamps
  updatedAt   DateTime @updatedAt
  
  @@index([key])
  @@index([enabled])
}
